# Copy this file to `.env` (git-ignored) and fill in the values.
# Secrets are read from the environment only and never committed (PRD NFR-3).

# Anthropic — default provider for the ArchAgent crew and `graphify extract`.
ANTHROPIC_API_KEY=

# Optional alternative providers that Graphify also supports.
OPENAI_API_KEY=
GEMINI_API_KEY=
